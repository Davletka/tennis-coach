# Copy this file to .env and fill in your values.
# Never commit your .env file to version control.

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Cloudflare R2 (video storage)
# Account ID: Cloudflare dashboard → right sidebar
# Access keys: R2 → Manage R2 API tokens
R2_ACCOUNT_ID=...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET_NAME=tennis-coaching

# PostgreSQL (session history)
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tennis_coach

# Redis (Celery broker + job state)
REDIS_URL=redis://localhost:6379/0

# Google OAuth
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# JWT
JWT_SECRET=generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# Frontend
FRONTEND_URL=http://localhost:3000
